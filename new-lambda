def fetch_application_logs(log_group_name, error_keyword, alarm_severity, alarm_timestamp_str):
    """
    Fetches relevant application logs from CloudWatch Logs.
    """
    try:
        logger.info(f"Attempting to fetch application logs for LogGroup: {log_group_name}, Keyword: {error_keyword}, Severity: {alarm_severity}")

        # Determine the filter pattern based on severity and keyword
        # This mirrors the logic in your Terraform metric filters
        if alarm_severity.lower() == "low":
            # For low severity, original pattern checks WARN or ERROR, and message or errorMessage
            # We simplify here for the lambda query to focus on the keyword in common fields
            # This pattern assumes 'log_processed' is the parsed JSON structure of your logs.
            # If your logs are not JSON or 'log_processed' isn't the key, this needs adjustment.
            filter_pattern = f'{{ ($.log_processed.level = "WARN" || $.log_processed.level = "ERROR") && (($.log_processed.message = "*{error_keyword}*") || ($.log_processed.errorMessage = "*{error_keyword}*")) }}'
        else: # Medium or High
            filter_pattern = f'{{ $.log_processed.level = "ERROR" && ($.log_processed.errorMessage = "*{error_keyword}*") }}'
        
        logger.info(f"Constructed filter pattern: {filter_pattern}")

        # Calculate time window for log query
        # Alarm timestamp is like "2024-03-15T10:30:00.000+0000"
        # Convert to datetime object, then to milliseconds epoch
        try:
            # Handle potential timezone info if present, assume UTC if not
            if '+' in alarm_timestamp_str:
                alarm_dt = datetime.strptime(alarm_timestamp_str, "%Y-%m-%dT%H:%M:%S.%f%z")
            else: # If no timezone, assume UTC (CloudWatch events are UTC)
                alarm_dt = datetime.strptime(alarm_timestamp_str, "%Y-%m-%dT%H:%M:%S.%fZ").replace(tzinfo=timezone.utc)
        except ValueError: # Fallback for slightly different formats without milliseconds
             if '+' in alarm_timestamp_str:
                alarm_dt = datetime.strptime(alarm_timestamp_str, "%Y-%m-%dT%H:%M:%S%z")
             else:
                alarm_dt = datetime.strptime(alarm_timestamp_str, "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=timezone.utc)


        end_time = int(alarm_dt.timestamp() * 1000)
        start_time = int((alarm_dt - timedelta(minutes=LOG_FETCH_WINDOW_MINUTES)).timestamp() * 1000)

        logger.info(f"Querying logs from {start_time} to {end_time}")

        response = logs_client.filter_log_events(
            logGroupName=log_group_name,
            filterPattern=filter_pattern,
            startTime=start_time,
            endTime=end_time,
            limit=MAX_LOG_EVENTS_TO_FETCH # Limit the number of events
        )
        
        log_events_details = []
        if response and 'events' in response:
            for event in response['events']:
                log_events_details.append(f"Timestamp: {datetime.fromtimestamp(event['timestamp']/1000, tz=timezone.utc).isoformat()}, Message: {event['message']}")
            logger.info(f"Found {len(response['events'])} relevant log events.")
            return "\n".join(log_events_details) if log_events_details else "No specific log events found matching the criteria in the time window."
        else:
            logger.info("No log events found for the given filter and time window.")
            return "No log events found for the given filter and time window."

    except Exception as e:
        logger.error(f"Error fetching application logs: {e}", exc_info=True)
        return f"Error fetching logs: {str(e)}"


