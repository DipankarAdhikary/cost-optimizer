import json
import boto3
import os
import logging
from datetime import datetime, timezone, timedelta
import copy # For deep copying the event

# Initialize AWS clients
sns_client = boto3.client('sns')
logs_client = boto3.client('logs')
cloudwatch_client = boto3.client('cloudwatch')

# Set up logging
logger = logging.getLogger()
logger.setLevel(os.environ.get('LOG_LEVEL', 'INFO').upper())

# Environment Variables
TARGET_SNS_TOPIC_ARN = os.environ.get('TARGET_SNS_TOPIC_ARN')
# Time window for log query if reasonData.startDate is not available
LOG_QUERY_WINDOW_MINUTES_FALLBACK = int(os.environ.get('LOG_QUERY_WINDOW_MINUTES_FALLBACK', '5'))
# Max characters for stack trace in the final message
MAX_STACK_TRACE_LENGTH = int(os.environ.get('MAX_STACK_TRACE_LENGTH', '1000'))
# How many log events to retrieve. We typically only need one.
LOG_EVENTS_LIMIT = int(os.environ.get('LOG_EVENTS_LIMIT', '1'))


def parse_datetime_from_iso(timestamp_str):
    """Safely parse ISO 8601 timestamp string."""
    try:
        return datetime.fromisoformat(timestamp_str)
    except ValueError:
        # Handle cases like "Z" for UTC timezone if fromisoformat has issues on older Pythons
        # or slightly non-compliant formats. For modern Python 3.9+, fromisoformat is robust.
        logger.warning(f"Could not parse timestamp '{timestamp_str}' directly, attempting with Z replacement.")
        if timestamp_str.endswith('Z'):
            return datetime.fromisoformat(timestamp_str.replace('Z', '+00:00'))
        raise

def get_alarm_tags(alarm_arn):
    """Retrieve tags for a given CloudWatch Alarm ARN."""
    try:
        response = cloudwatch_client.list_tags_for_resource(ResourceARN=alarm_arn)
        tags = {tag['Key']: tag['Value'] for tag in response.get('Tags', [])}
        logger.info(f"Retrieved tags for alarm {alarm_arn}: {tags}")
        return tags
    except Exception as e:
        logger.error(f"Error retrieving tags for alarm {alarm_arn}: {e}")
        return {}

def fetch_triggering_log_event(log_group_name, error_keyword, alarm_event_data):
    """
    Queries CloudWatch Logs for events that likely triggered the alarm.
    """
    log_events_found = []

    # Determine query time window
    # Preferred: Use reasonData.startDate and alarm period
    try:
        reason_data_str = alarm_event_data['state'].get('reasonData', '{}')
        reason_data = json.loads(reason_data_str)
        log_event_start_time_str = reason_data.get('startDate')

        if log_event_start_time_str:
            query_start_dt = parse_datetime_from_iso(log_event_start_time_str)
            
            alarm_period_seconds = 60  # Default
            metrics_config = alarm_event_data['configuration'].get('metrics', [])
            if metrics_config and 'metricStat' in metrics_config[0] and 'period' in metrics_config[0]['metricStat']:
                alarm_period_seconds = metrics_config[0]['metricStat']['period']
            else:
                logger.warning("Could not determine alarm period from event, defaulting to 60 seconds.")
            
            query_end_dt = query_start_dt + timedelta(seconds=alarm_period_seconds)
            
            start_time_ms = int(query_start_dt.timestamp() * 1000)
            end_time_ms = int(query_end_dt.timestamp() * 1000)
            logger.info(f"Using precise time window from alarm reasonData: {query_start_dt} to {query_end_dt}")
        else:
            raise ValueError("startDate not found in reasonData")

    except (ValueError, KeyError, TypeError) as e:
        logger.warning(f"Could not determine precise time window from reasonData ({e}). Falling back.")
        alarm_state_change_timestamp_str = alarm_event_data['state']['timestamp']
        alarm_state_change_dt = parse_datetime_from_iso(alarm_state_change_timestamp_str)
        
        # Query a window ending at the alarm state change time
        end_time_dt = alarm_state_change_dt
        start_time_dt = end_time_dt - timedelta(minutes=LOG_QUERY_WINDOW_MINUTES_FALLBACK)
        
        start_time_ms = int(start_time_dt.timestamp() * 1000)
        end_time_ms = int(end_time_dt.timestamp() * 1000)
        logger.info(f"Using fallback time window: {start_time_dt} to {end_time_dt}")

    # Construct filter pattern based on the error keyword that triggered the alarm
    # This should mirror how the metric filter was defined.
    # Assuming ErrorKeyword is the raw keyword.
    filter_pattern = f'{{ ($.log_processed.message = "*{error_keyword}*") || ($.log_processed.errorMessage = "*{error_keyword}*") }}'
    logger.info(f"Using filter pattern: {filter_pattern} for log group {log_group_name}")

    try:
        paginator = logs_client.get_paginator('filter_log_events')
        page_iterator = paginator.paginate(
            logGroupName=log_group_name,
            startTime=start_time_ms,
            endTime=end_time_ms,
            filterPattern=filter_pattern,
            limit=LOG_EVENTS_LIMIT # Fetch a small number of events
        )
        for page in page_iterator:
            log_events_found.extend(page.get('events', []))
            if len(log_events_found) >= LOG_EVENTS_LIMIT:
                break
        
        if log_events_found:
            # filter_log_events returns in ascending order by timestamp.
            # We want the latest one matching the criteria within the window.
            logger.info(f"Found {len(log_events_found)} log event(s). Taking the last one.")
            return log_events_found[-1] # Return the most recent one
        else:
            logger.info("No matching log events found within the time window and filter pattern.")
            return None

    except Exception as e:
        logger.error(f"Error querying CloudWatch Logs: {e}")
        return None


def lambda_handler(event, context):
    logger.info(f"Received event: {json.dumps(event)}")

    if not TARGET_SNS_TOPIC_ARN:
        logger.error("TARGET_SNS_TOPIC_ARN environment variable not set. Exiting.")
        return {"statusCode": 500, "body": "Configuration error"}

    original_event = event # Keep a reference to the original raw event for 'rawevent' attribute

    try:
        alarm_arn = original_event.get('alarmArn')
        alarm_data = original_event.get('alarmData')

        if not alarm_arn or not alarm_data:
            logger.error("Event is not a valid CloudWatch Alarm event. Missing alarmArn or alarmData.")
            return {"statusCode": 400, "body": "Invalid event format"}

        # --- Information directly from the alarm event ---
        alarm_name = alarm_data.get('alarmName', 'N/A')
        # alarm_description is from alarm_data.configuration.description
        alarm_description_from_event = alarm_data.get('configuration', {}).get('description', 'N/A')
        account_id = original_event.get('accountId', 'N/A')
        region = original_event.get('region', 'N/A')
        state_change_time = original_event.get('time', 'N/A') # This is the event time from top level
        new_state_value = alarm_data.get('state', {}).get('value', 'N/A')
        original_alarm_reason = alarm_data.get('state', {}).get('reason', '')

        # --- Fetch alarm tags (these will go into MessageAttributes) ---
        alarm_tags = get_alarm_tags(alarm_arn)
        log_group_name_tag = alarm_tags.get('LogGroupName')
        error_keyword_tag = alarm_tags.get('ErrorKeyword')
        # Add other important tags you want to pass to xMatters via MessageAttributes
        # For example: severity, type, incidentgroup, callout, AlarmCategory

        log_details_snippet = "\n\n--- No specific log event details could be retrieved ---"

        if log_group_name_tag and error_keyword_tag:
            # ... (log fetching logic as before - this remains the same) ...
            # This populates log_details_snippet
            triggering_log = fetch_triggering_log_event(log_group_name_tag, error_keyword_tag, alarm_data)
            if triggering_log:
                # ... (parsing logic for triggering_log as before) ...
                # This updates log_details_snippet
                pass # Placeholder for the detailed parsing logic already outlined

        # --- Construct the SNS Message body (JSON string) ---
        # This structure mimics what lambda-incident's `message` string would contain
        final_sns_message_payload = {
            "AlarmName": alarm_name,
            "AlarmDescription": alarm_description_from_event, 
            "AWSAccountId": account_id,
            "Region": region,
            "StateChangeTime": state_change_time, # Using the top-level event time
            "NewStateValue": new_state_value,
            "NewStateReason": original_alarm_reason + log_details_snippet
        }
        sns_message_body_str = json.dumps(final_sns_message_payload)

        # --- Construct SNS MessageAttributes ---
        sns_message_attributes = {
            'source': {'DataType': 'String', 'StringValue': 'aws.cloudwatch'}, # To identify origin
            'rawevent': {'DataType': 'String', 'StringValue': json.dumps(original_event)},
            'fromlambda': {'DataType': 'String', 'StringValue': context.function_name}
        }

        
        # Define which tags from the alarm should be passed as MessageAttributes
        # This list should include tags xMatters understands.
        tags_for_xmatters = ['severity', 'type', 'incidentgroup', 'callout', 
                               'LogGroupName', 'ErrorKeyword', 'AlarmCategory', 'hostname', 'os', 'disk', 'ec2instanceid']
                               # Add any other tags your xMatters setup might use

        for tag_key, tag_value in alarm_tags.items():
            if tag_key in tags_for_xmatters:
                sns_message_attributes[tag_key] = {'DataType': 'String', 'StringValue': tag_value}
            else:
                logger.debug(f"Tag '{tag_key}' not in tags_for_xmatters list, not adding to MessageAttributes.")
        
        # Ensure default severity if not present (similar to lambda-incident)
        if 'severity' not in sns_message_attributes and 'severity' not in alarm_tags:
            sns_message_attributes['severity'] = {'DataType': 'String', 'StringValue': 'Medium'} # Default
        if 'type' not in sns_message_attributes and 'type' not in alarm_tags:
             sns_message_attributes['type'] = {'DataType': 'String', 'StringValue': 'Application Error'} # Default for app errors


        # --- Compile Subject for SNS ---
        alarm_state_for_subject = new_state_value
        if alarm_state_for_subject == 'ALARM':
            alarm_state_for_subject = 'Alarm' # Match lambda-incident's subject format
        
        sns_subject = f"AWS {alarm_state_for_subject}: {alarm_name}"
        if "OK" in new_state_value: # If it's an OK to clear alarm
             sns_subject = f"AWS OK: {alarm_name}"


        logger.info(f"Publishing to SNS topic: {TARGET_SNS_TOPIC_ARN}")
        logger.debug(f"SNS Subject: {sns_subject}")
        logger.debug(f"SNS Message Body: {sns_message_body_str}")
        logger.debug(f"SNS Message Attributes: {json.dumps(sns_message_attributes)}")
        
        sns_client.publish(
            TopicArn=TARGET_SNS_TOPIC_ARN,
            Subject=sns_subject,
            Message=sns_message_body_str,
            MessageAttributes=sns_message_attributes
        )
        logger.info("Successfully published message to SNS.")
        return {"statusCode": 200, "body": "Message published successfully"}

    except Exception as e:
        logger.error(f"An unexpected error occurred in lambda_handler: {e}", exc_info=True)
        return {"statusCode": 500, "body": f"Internal server error: {str(e)}"}
