# Use this to parse cloudwatch alarms
def event_is_cloudwatch(event,rawevent,allowedTags,sns_topic_arn):
    
    # Print the list of supported alarm tags
    logger.info("Supported Alarm Tags:") # Changed
    logger.info(allowedTags) # Changed
    
    # Parse out desired data
    source = event['source']
    alarm_arn = event['alarmArn']
    alarm_name = event['alarmData']['alarmName']
    # Alarm description can be None, provide default
    alarm_description_raw = event['alarmData']['configuration'].get('description')
    alarm_description = alarm_description_raw if alarm_description_raw is not None else "N/A"
    account_id = event['accountId']
    time_str = event['time'] # This is StateChangeTime, keep as string for now
    region = event['region']
    alarm_state = event['alarmData']['state']['value']
    alarm_reason = event['alarmData']['state']['reason']
    
    alarm_state_for_subject = alarm_state
    if (alarm_state_for_subject == 'ALARM'):
        alarm_state_for_subject = 'Alarm'

    # Compile Subject for SNS Topic
    subject = (
        f"AWS {alarm_state_for_subject}: {alarm_name}"
    )
    
    # Base message dictionary
    message_dict = {
        "AlarmName": alarm_name,
        "AlarmDescription": alarm_description,
        "AWSAccountId": account_id,
        "Region": region,
        "StateChangeTime": time_str, 
        "NewStateValue": alarm_state,
        "NewStateReason": alarm_reason
    }
    
    # Create dictionary of fields for SNS MessageAttributes value
    messageAttributes = {}
    messageAttributes['source'] = {"DataType": "String", "StringValue": source}
    messageAttributes['rawevent'] = {"DataType": "String", "StringValue": rawevent}
    messageAttributes['fromlambda'] = {"DataType": "String", "StringValue": "yes"}
    
    # Get alarm tags
    alarm_tags = cloudwatch.list_tags_for_resource(ResourceARN=alarm_arn)['Tags']
    
    # Initialize maintenance flag
    inMaintenance = 'false'
    
    # Add alarm tags to the messageAttributes dictionary
    # And also store them for easier access later
    current_alarm_tags = {}
    severity_found = ''
    type_found = ''
    alarm_category = '' # To check if it's an Application alarm

    for tag in alarm_tags:
        alarm_tag_key = tag['Key']
        alarm_tag_value = tag['Value']
        current_alarm_tags[alarm_tag_key] = alarm_tag_value # Store for direct use
        
        # Only include supported alarm tags in messageAttributes
        if alarm_tag_key in allowedTags:
            logger.info(f"Found Alarm Tag: {alarm_tag_key} = {alarm_tag_value}") # Changed
            messageAttributes[alarm_tag_key] = {"DataType": "String", "StringValue": alarm_tag_value}
        
            if alarm_tag_key == 'ec2instanceid':
                instance = ec2.Instance(alarm_tag_value)
                if not (instance == ''): # This check might be problematic if instance is None
                    inMaintenance = check_maintenance(instance,"FIS-Monitoring-Maintenance")
                    
            if alarm_tag_key == 'severity':
                severity_found = "yes"
            
            if alarm_tag_key == 'type':
                type_found = "yes"
            
            if alarm_tag_key == 'AlarmCategory':
                alarm_category = alarm_tag_value

    # Include the default severity if it wasn't found in a tag
    if severity_found == '':
        messageAttributes['severity'] = {"DataType": "String", "StringValue": "Medium"}
        current_alarm_tags['severity'] = "Medium" # Also update local cache
        
    # Include the default type if it wasn't found in a tag
    if type_found == '':
        messageAttributes['type'] = {"DataType": "String", "StringValue": "unspecified"}
        current_alarm_tags['type'] = "unspecified" # Also update local cache

    # --- Application Log Fetching Logic ---
    # Check if this is an application alarm based on AlarmCategory tag or content of 'type' tag
    is_application_alarm = False
    if alarm_category.lower() == "application":
        is_application_alarm = True
    elif "application error" in current_alarm_tags.get('type', '').lower():
        is_application_alarm = True
        logger.info("Identified as application alarm based on 'type' tag content.")


    if is_application_alarm:
        log_group_name_from_tag = current_alarm_tags.get('LogGroupName')
        error_keyword_from_tag = current_alarm_tags.get('ErrorKeyword')
        alarm_severity_from_tag = current_alarm_tags.get('severity', 'Medium') # Default to Medium if not set

        if log_group_name_from_tag and error_keyword_from_tag:
            logger.info(f"Application alarm detected. Fetching logs for LG: {log_group_name_from_tag}, Keyword: {error_keyword_from_tag}")
            log_details_str = fetch_application_logs(
                log_group_name_from_tag,
                error_keyword_from_tag,
                alarm_severity_from_tag,
                time_str # Pass the original alarm state change time
            )
            message_dict["LogDetails"] = log_details_str
        else:
            logger.warning("Application alarm detected, but LogGroupName or ErrorKeyword tag is missing. Cannot fetch logs.")
            message_dict["LogDetails"] = "Log fetching skipped: LogGroupName or ErrorKeyword tag missing from alarm."
    
    # Convert final message dict to JSON string
    message = json.dumps(message_dict)

    # Check message size before publishing
    if sys.getsizeof(message) > MAX_LOG_MESSAGE_LENGTH_BYTES:
        logger.warning(f"Message size ({sys.getsizeof(message)} bytes) exceeds limit ({MAX_LOG_MESSAGE_LENGTH_BYTES} bytes). Truncating LogDetails.")
        # Attempt to truncate LogDetails; this is a basic truncation.
        # A more sophisticated approach might summarize or indicate truncation clearly.
        if "LogDetails" in message_dict:
            original_log_details_len = len(message_dict["LogDetails"])
            # Estimate overhead of other fields (generous 2KB)
            overhead = 2048 
            available_for_logs = MAX_LOG_MESSAGE_LENGTH_BYTES - (sys.getsizeof(json.dumps(message_dict)) - len(message_dict["LogDetails"].encode('utf-8'))) - overhead
            
            if available_for_logs > 0:
                 # Truncate log_details by bytes, not characters, to be safe
                encoded_logs = message_dict["LogDetails"].encode('utf-8')
                if len(encoded_logs) > available_for_logs:
                    truncated_logs_bytes = encoded_logs[:available_for_logs]
                    # Try to decode back, ignore errors for partial unicode characters
                    message_dict["LogDetails"] = truncated_logs_bytes.decode('utf-8', 'ignore') + \
                                              f"... [TRUNCATED from original {original_log_details_len} chars]"
                # else: fits as is
            else: # No space for logs or negative calculation
                message_dict["LogDetails"] = f"[LogDetails TRUNCATED due to message size limit. Original length {original_log_details_len} chars]"

            message = json.dumps(message_dict) # Re-serialize with truncated logs

    # Publish the message to the SNS topic
    # Unless there's a FIS-Monitoring-Maintenance=true tag on the EC2 instance
    response = "Alarm ignored due to FIS-Monitoring-Maintenance=true tag on the EC2 instance"
    if (inMaintenance == 'false'):
        response = publish_alarm(sns_topic_arn,subject,message,messageAttributes)
        logger.info("Publishing event to SNS Topic") # Changed

    # Print and return the response
    logger.info(response) # Changed
    return(response)


    
# This function publishes to the SNS Topic
def publish_alarm(sns_topic_arn,subject,message,messageAttributes):
    response = sns.publish(TopicArn=sns_topic_arn, Subject=subject, Message=message, MessageAttributes=messageAttributes)
    
    # Return the response
    return(response)
    

# This function gets the SNS topic         
def get_sns_topic():
    existingTopics = sns.list_topics()

    topicExists = ''
    topicArn = ''
    for topic in existingTopics["Topics"]:
      arn = topic.get("TopicArn")
      # Ensure XMATTERS_TOPIC_NAME is not empty and is a string
      if XMATTERS_TOPIC_NAME and isinstance(XMATTERS_TOPIC_NAME, str):
        p = re.compile(r'' + XMATTERS_TOPIC_NAME + '$') # Match end of string for exact topic name
        foundIt = p.search(arn)
        if (foundIt):
          topicExists='yes'
          topicArn=arn
          logger.info(XMATTERS_TOPIC_NAME + " exists.") # Changed
          break # Found the topic, no need to continue loop
      else:
        logger.error("XMATTERS_TOPIC_NAME is not configured properly.") # Changed
        return ''


    if topicArn == '':
        logger.warning(XMATTERS_TOPIC_NAME + " does not exist.") # Changed

    return(topicArn)


# This function checks for the maintenance tag if we have the instance ID
def check_maintenance(instance,tagName):
  tagValue = 'false'
  try:
    # instance.tags might be None if the instance object is not fully loaded or has no tags
    if instance.tags: 
      for tag in instance.tags:
          if (tag['Key']==tagName):
            tagValue=(tag['Value'])
            logger.info(f"EC2 maintenance tag found: {tagName} = {tagValue}") # Changed
            tagValue = tagValue.lower() # Ensure lowercase for comparison
            break # Found the tag
    if not (tagValue == 'true'):
        tagValue = 'false'
  except Exception as e:
      logger.error(f"Error checking maintenance tag for instance {instance.id if instance else 'N/A'}: {e}", exc_info=True)
      tagValue = 'false' # Default to not in maintenance on error
      
  return tagValue

